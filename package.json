{
  "name": "wat321",
  "displayName": "WAT321",
  "description": "Willy's AI Tools - Real-time Claude & Codex usage widgets",
  "version": "1.2.9",
  "publisher": "WillyDrucker",
  "repository": {
    "type": "git",
    "url": "https://github.com/WillyDrucker/WAT321"
  },
  "homepage": "https://github.com/WillyDrucker/WAT321",
  "bugs": {
    "url": "https://github.com/WillyDrucker/WAT321/issues"
  },
  "license": "MIT",
  "keywords": [
    "claude",
    "codex",
    "anthropic",
    "openai",
    "usage",
    "limits",
    "tokens",
    "context window",
    "status bar",
    "AI"
  ],
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wat321.clearAllSettings",
        "title": "WAT321: Reset WAT321"
      },
      {
        "command": "wat321.showProviderHealth",
        "title": "WAT321: Show Provider Health"
      },
      {
        "command": "wat321.epicHandshake.enable",
        "title": "WAT321: Enable Epic Handshake"
      },
      {
        "command": "wat321.epicHandshake.disable",
        "title": "WAT321: Disable Epic Handshake"
      },
      {
        "command": "wat321.epicHandshake.resetCodexSession",
        "title": "WAT321: Epic Handshake - Reset Codex Session"
      },
      {
        "command": "wat321.epicHandshake.deleteCodexSession",
        "title": "WAT321: Epic Handshake - Delete Codex Session (destructive)"
      },
      {
        "command": "wat321.epicHandshake.deleteAllCodexSessions",
        "title": "WAT321: Epic Handshake - Delete All Codex Sessions (destructive)"
      },
      {
        "command": "wat321.epicHandshake.manage",
        "title": "WAT321: Epic Handshake - Manage"
      },
      {
        "command": "wat321.epicHandshake.stageClipboardImage",
        "title": "WAT321: Epic Handshake - Stage Clipboard Image for Codex"
      },
      {
        "command": "wat321.epicHandshake.restartCodexBridge",
        "title": "WAT321: Epic Handshake - Restart Codex Bridge"
      }
    ],
    "icons": {
      "wat321-epic-handshake": {
        "description": "Epic Handshake",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E001"
        }
      },
      "wat321-square-alert": {
        "description": "Square with alert bang",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E002"
        }
      },
      "wat321-square-arrow-left": {
        "description": "Square with left arrow",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E003"
        }
      },
      "wat321-square-arrow-right": {
        "description": "Square with right arrow",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E004"
        }
      },
      "wat321-square-bolt": {
        "description": "Square with lightning bolt",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E005"
        }
      },
      "wat321-square-check": {
        "description": "Square with checkmark",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E006"
        }
      },
      "wat321-square-error": {
        "description": "Square with X",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E007"
        }
      },
      "wat321-square-five": {
        "description": "Square with number 5",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E008"
        }
      },
      "wat321-square-four": {
        "description": "Square with number 4",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E009"
        }
      },
      "wat321-square-info": {
        "description": "Square with info i",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E00A"
        }
      },
      "wat321-square-mail-open": {
        "description": "Square with open envelope",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E00B"
        }
      },
      "wat321-square-mail": {
        "description": "Square with closed envelope",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E00C"
        }
      },
      "wat321-square-one": {
        "description": "Square with number 1",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E00D"
        }
      },
      "wat321-square-pause": {
        "description": "Square with pause bars",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E00E"
        }
      },
      "wat321-square-play": {
        "description": "Square with play triangle",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E00F"
        }
      },
      "wat321-square-three": {
        "description": "Square with number 3",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E010"
        }
      },
      "wat321-square-two": {
        "description": "Square with number 2",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E011"
        }
      },
      "wat321-square": {
        "description": "Empty square",
        "default": {
          "fontPath": "media/fonts/wat321-icons.woff",
          "fontCharacter": "\\E012"
        }
      }
    },
    "configuration": [
      {
        "title": "Claude",
        "order": 1,
        "properties": {
          "wat321.enableClaude": {
            "type": "boolean",
            "default": true,
            "order": 1,
            "markdownDescription": "Enable Claude widgets (usage bars and session tokens). Hidden automatically if the Claude CLI is not installed."
          }
        }
      },
      {
        "title": "Codex",
        "order": 2,
        "properties": {
          "wat321.enableCodex": {
            "type": "boolean",
            "default": true,
            "order": 1,
            "markdownDescription": "Enable Codex widgets (usage bars and session tokens). Hidden automatically if the Codex CLI is not installed."
          }
        }
      },
      {
        "title": "Notifications",
        "order": 3,
        "properties": {
          "wat321.notifications.mode": {
            "type": "string",
            "default": "System Notifications",
            "scope": "application",
            "enum": [
              "Off",
              "Auto",
              "System Notifications",
              "In-App"
            ],
            "enumDescriptions": [
              "Notification services stopped and disabled",
              "Receive system notifications when your editor is unfocused, in-app when focused",
              "Only use Windows, Linux and macOS notifications",
              "Only use editor in-app notifications"
            ],
            "order": 1,
            "markdownDescription": "Notify you when Claude or Codex finishes a response."
          },
          "wat321.notifications.claude": {
            "type": "boolean",
            "default": true,
            "scope": "application",
            "order": 2,
            "markdownDescription": "Show notifications for Claude sessions. Requires Claude to be enabled."
          },
          "wat321.notifications.codex": {
            "type": "boolean",
            "default": true,
            "scope": "application",
            "order": 3,
            "markdownDescription": "Show notifications for Codex sessions. Requires Codex to be enabled."
          }
        }
      },
      {
        "title": "General",
        "order": 4,
        "properties": {
          "wat321.displayMode": {
            "type": "string",
            "default": "Auto",
            "enum": [
              "Auto",
              "Full",
              "Compact",
              "Minimal"
            ],
            "enumDescriptions": [
              "Automatic - Full when only one provider is active, Compact when both are active",
              "Full progress bars (10 blocks)",
              "Compact progress bars (5 blocks), slim session tokens",
              "Text-only status bar, progress bars move to tooltips on hover"
            ],
            "order": 1,
            "markdownDescription": "Status bar display density. Auto adjusts based on how many providers are active."
          },
          "wat321.statusBarPriority": {
            "type": "number",
            "default": 1001,
            "order": 2,
            "markdownDescription": "Base priority for WAT321 status bar items. Higher values appear further left. Adjust if widgets overlap with other extensions. *Requires window reload.*"
          },
          "wat321.enableHeatmap": {
            "type": "boolean",
            "default": true,
            "order": 3,
            "markdownDescription": "Enable heatmap colors on the usage progress bar. The bars gradually shift through warning colors as you get closer to your limits so tight sessions stand out at a glance."
          }
        }
      },
      {
        "title": "Epic Handshake (Claude to Codex Only)",
        "order": 5,
        "properties": {
          "wat321.epicHandshake.enabled": {
            "type": "boolean",
            "default": false,
            "scope": "application",
            "order": 1,
            "markdownDescription": "**Enable Epic Handshake - Experimental** - Lets you say things like *\"Ask Codex to review this\"* in any Claude session and have Codex actually answer, through a small bridge WAT321 runs locally. Both the Claude and Codex widgets must be on for this to work.\n\nAfter you turn this on, any active Claude sessions will need to be restarted so they can use the bridge. New sessions pick it up automatically. Same applies in reverse: turning this off fully removes the bridge for new Claude sessions, but already active Claude sessions keep a tiny cached reference to the bridge (roughly 20 tokens per prompt) until you restart the session. *Note: resuming an existing Claude session recalculates the entire balance on first load. In other words, just leave it off until you are done with the session - it unloads automatically when the session ends.*\n\nBridge can be paused by clicking on the Epic Handshake status bar and selecting **Pause** from the top of the dropdown."
          },
          "wat321.epicHandshake.suppressCodexNotifications": {
            "type": "boolean",
            "default": true,
            "scope": "application",
            "order": 4,
            "markdownDescription": "Suppress Codex completion notifications while the Epic Handshake bridge is active. You still get the Claude notification when Claude finishes integrating the reply, so there's no silent delivery - this just avoids two back-to-back notifications for the same exchange. Turn this off if you want Codex notifications regardless."
          },
          "wat321.epicHandshake.defaultWaitMode": {
            "type": "string",
            "default": "Adaptive",
            "scope": "application",
            "enum": [
              "Adaptive",
              "Fire-and-Forget"
            ],
            "enumDescriptions": [
              "Claude waits while Codex is demonstrably working. Heartbeat-driven, cuts on stall.",
              "Claude's tool returns immediately. Reply lands in the inbox when ready."
            ],
            "order": 5,
            "markdownDescription": "Starting wait mode after a VS Code restart. The Epic Handshake menu toggles between Adaptive and Fire-and-Forget live; this setting picks the baseline that restores on activate."
          }
        }
      },
      {
        "title": "Reset",
        "order": 6,
        "properties": {
          "wat321.clearAllData": {
            "type": "boolean",
            "default": false,
            "scope": "application",
            "order": 1,
            "markdownDescription": "**Reset WAT321** - Restore WAT321 to its defaults and clear everything it has stored locally. If any WAT321 tool appears unresponsive, this will reset all to a known-good state. A confirmation dialog will appear before resetting."
          }
        }
      }
    ]
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "lint": "eslint src/",
    "copy-assets": "node -e \"const fs=require('fs');const p=require('path');const srcDir=p.join('src','WAT321_EPIC_HANDSHAKE','bin');const dstDir=p.join('out','WAT321_EPIC_HANDSHAKE','bin');fs.mkdirSync(dstDir,{recursive:true});for(const f of ['channel.mjs','stage-clipboard.mjs']){fs.copyFileSync(p.join(srcDir,f),p.join(dstDir,f));}\"",
    "emit-prod-modules-manifest": "node -e \"const fs=require('fs');const lock=JSON.parse(fs.readFileSync('package-lock.json','utf8'));const prod=Object.entries(lock.packages||{}).filter(([k,m])=>k.startsWith('node_modules/')&&m.dev!==true).map(([k])=>k);fs.mkdirSync('out/WAT321_EPIC_HANDSHAKE',{recursive:true});fs.writeFileSync('out/WAT321_EPIC_HANDSHAKE/prod-modules.json',JSON.stringify(prod,null,2));console.log('prod-modules manifest:',prod.length,'entries');\"",
    "icons": "node scripts/buildIcons.mjs",
    "build": "npm run clean && npm run lint && tsc && npm run copy-assets && npm run emit-prod-modules-manifest",
    "watch": "tsc -w",
    "package": "npm run build && npm prune --omit=dev && npx vsce package && npm install"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "svgtofont": "^6.5.1",
    "typescript": "^6.0.2"
  }
}
