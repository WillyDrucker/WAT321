{
  "name": "wat321",
  "displayName": "WAT321 — Will's AI Tools",
  "description": "Real-time Claude & Codex status bar widgets: session usage, weekly limits, and more",
  "version": "1.0.0",
  "publisher": "WillyDrucker",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wat321.refresh",
        "title": "WAT321: Refresh Usage"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.0"
  }
}
